input {
    keyboard {
        xkb {
            layout us
            variant altgr-intl
            options caps:capslock
        }
        repeat-delay 330
        repeat-rate 50
 // numlock intentionally omitted → disabled on startup
    }
    touchpad {
        tap
        natural-scroll
        accel-speed -0.5
 // dwt / dwtp / drag-lock available if needed
    }
    mouse {
        accel-speed -0.5
    }
    // Focus window/output when cursor moves into it.
    // max-scroll-amount="0%" means only windows already fully visible get focus.
    focus-follows-mouse max-scroll-amount="0%"
}

